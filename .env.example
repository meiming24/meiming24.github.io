# Spotify Web Playback SDK
# Create an app at https://developer.spotify.com/dashboard
# Redirect URI must use 127.0.0.1 (localhost is no longer allowed):
# http://127.0.0.1:5173

VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173

# Use either an album ID or a playlist ID (album takes priority if both are set)
VITE_SPOTIFY_ALBUM_ID=5epJvt9jHbYI1j6WqCppGc
# VITE_SPOTIFY_PLAYLIST_ID=your_playlist_id

# Today panel — public holidays (ISO country code, e.g. US, GB, CA)
VITE_COUNTRY_CODE=US

# Optional — top headlines via NewsAPI (https://newsapi.org)
# Without this, headlines load from Google News RSS instead.
# VITE_NEWS_API_KEY=your_news_api_key

# Optional fallback coordinates if browser location is unavailable
# Prefer setting a city name instead:
# VITE_WEATHER_CITY=Hanoi
# VITE_WEATHER_LAT=21.0285
# VITE_WEATHER_LON=105.8542

# Tamagotchi P1 — BrickEmuPy assets in public/tamagotchi/assets/
#   TamagotchiP1.brick, TamagotchiP1.svg, TamagotchiP1.bin (ROM not committed)
